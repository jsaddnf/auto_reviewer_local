#!/bin/bash
# autoreviewer - main CLI dispatcher
#
# Subcommands:
#   enable [--repo PATH]      enable globally or for a specific repo
#   disable [--repo PATH]     disable globally or for a specific repo
#   status                    show current state
#   update [--no-pull]        pull latest source and reinstall the tool
#   run [<commit>] [opts]     manually trigger a review (default: HEAD, sync)
#   log [-n N] [--severity X] list recent reviews
#   show [<hash>] [--open]    show a specific review
#   clean [--all|--older-than Xd]  clean up review files
#   cancel                    kill the currently running review
#   uninstall                 uninstall autoreviewer

set -u

AUTOREVIEWER_HOME="${AUTOREVIEWER_HOME:-$HOME/.autoreviewer}"
GLOBAL_CONFIG="$AUTOREVIEWER_HOME/config.json"

if [ -f "$AUTOREVIEWER_HOME/lib/config.sh" ]; then
    # shellcheck disable=SC1091
    source "$AUTOREVIEWER_HOME/lib/config.sh"
fi

# ---------- helpers ----------

die() { echo "Error: $*" >&2; exit 1; }

require_repo() {
    git rev-parse --git-dir >/dev/null 2>&1 || die "not in a git repository"
}

cmd_help() {
    cat <<'EOF'
autoreviewer - automatic code review on every commit

USAGE
  autoreviewer <command> [options]

COMMANDS
  install [--repo PATH] [--uninstall]
                                  Set up the trigger for current/given repo.
                                  Handles repos that override core.hooksPath
                                  (Husky, Lefthook, project .githooks, etc.)
  enable [--repo PATH]            Enable autoreviewer (globally or for a repo)
  disable [--repo PATH]           Disable autoreviewer (globally or for a repo)
  status                          Show current state and config
  update [--no-pull]              Pull latest source and re-run install.sh
                                    --no-pull   Skip git pull, just rebuild
  run [<commit>...] [options]     Manually trigger a review
                                    --squash      review the span as ONE diff
                                    --async       run in background
                                    --no-notify   skip notification
                                    --open        open .md when done
  log [-n N] [--severity LEVEL]   List recent reviews in current repo
  show [<hash>] [options]         Show a review
                                    --open        open in default app
                                    --json        print raw JSON
  clean --all | --older-than 30d  Clean up review files in current repo
  cancel                          Kill the currently running review
  heal                            Re-apply chain mode if core.hooksPath was
                                    overwritten (no-op when healthy). Used
                                    by the shell prompt hook.
  shell-hook <install|uninstall|status>
                                  Manage the precmd/PROMPT_COMMAND snippet
                                    in your ~/.zshrc or ~/.bashrc that runs
                                    'heal' automatically after every command.
  path-hook <install|uninstall|status>
                                  Manage the `export PATH=...` block that
                                    makes the autoreviewer CLI findable
                                    (~/.local/bin not on macOS default PATH).
  config <get|set|unset|list> ... Read/write JSON config without hand-editing.
                                    e.g. autoreviewer config set timeout_seconds 600
                                    Use --repo PATH to edit per-repo override.
  uninstall                       Uninstall autoreviewer entirely
  help                            Show this help

ENVIRONMENT
  AUTOREVIEWER_SKIP=1 git commit  Skip review for a single commit
EOF
}

# ---------- enable / disable ----------

cmd_enable() {
    local repo=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --repo) repo="$2"; shift 2 ;;
            *) die "unknown option: $1" ;;
        esac
    done

    if [ -n "$repo" ]; then
        cd "$repo" || die "cannot cd to $repo"
        require_repo
        ar_config_set_repo enabled true
        local abs
        abs=$(pwd)
        ar_blacklist_remove "$abs"
        echo "✅ enabled for repo: $abs"
    else
        ar_config_set_global enabled true
        echo "✅ globally enabled"
    fi
}

cmd_disable() {
    local repo=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --repo) repo="$2"; shift 2 ;;
            *) die "unknown option: $1" ;;
        esac
    done

    if [ -n "$repo" ]; then
        cd "$repo" || die "cannot cd to $repo"
        require_repo
        ar_config_set_repo enabled false
        local abs
        abs=$(pwd)
        ar_blacklist_add "$abs"
        echo "🛑 disabled for repo: $abs"
    else
        ar_config_set_global enabled false
        echo "🛑 globally disabled"
    fi
}

# ---------- status ----------

cmd_status() {
    echo "autoreviewer"
    echo "============"
    echo "Tool home:    $AUTOREVIEWER_HOME"

    local cmd
    cmd=$(ar_config_get command)
    echo "Review tool:  ${cmd:-claude}"

    local global_enabled
    if [ -f "$GLOBAL_CONFIG" ]; then
        global_enabled=$(jq -r '.enabled // true' "$GLOBAL_CONFIG" 2>/dev/null)
    else
        global_enabled="true"
    fi
    if [ "$global_enabled" = "true" ]; then
        echo "Master switch: ON   (autoreviewer disable to pause everywhere)"
    else
        echo "Master switch: OFF 🛑 (autoreviewer enable to resume)"
    fi

    # Shell prompt hook — runs 'autoreviewer heal' after every command in
    # interactive shells. Covers any tool that overwrites core.hooksPath
    # (pod install, npm install, husky install, etc.).
    echo "Shell hook:   $(_ar_shell_hook_status_line)"
    # PATH hook — adds ~/.local/bin (or wherever the CLI lives) to PATH
    # so `autoreviewer` is findable. macOS doesn't include ~/.local/bin
    # by default.
    echo "PATH hook:    $(_ar_path_hook_status_line)"

    # Legacy global hook check — still report if user has it from old install
    local global_hp
    global_hp=$(git config --global --get core.hooksPath 2>/dev/null || echo "")
    if [ "$global_hp" = "$AUTOREVIEWER_HOME/hooks" ] || [ "$global_hp" = "$AUTOREVIEWER_HOME/hooks/" ]; then
        echo "Global hook:  $global_hp  (legacy global install — every repo on this machine inherits autoreviewer)"
    fi

    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        echo ""
        echo "(Not in a git repo — cd into one and run 'autoreviewer status' to check it.)"
        return 0
    fi

    local repo
    repo=$(git rev-parse --show-toplevel)
    echo ""
    echo "Current repo: $repo"

    # Determine install state for this repo
    local local_hp effective effective_abs our_hooks
    our_hooks="$AUTOREVIEWER_HOME/hooks"
    local_hp=$(git config --local --get core.hooksPath 2>/dev/null || echo "")
    effective=$(git config --get core.hooksPath 2>/dev/null || echo "")
    effective_abs="$effective"
    if [ -n "$effective" ] && [[ "$effective" != /* ]]; then
        effective_abs="$repo/$effective"
    fi
    effective_abs="${effective_abs%/}"
    our_hooks="${our_hooks%/}"

    # Read chained_hooks_path from .git/autoreviewer.json
    local repo_cfg chained
    repo_cfg="$(git rev-parse --absolute-git-dir)/autoreviewer.json"
    chained=""
    if [ -f "$repo_cfg" ]; then
        chained=$(jq -r '.chained_hooks_path // empty' "$repo_cfg" 2>/dev/null)
    fi

    if [ -z "$effective" ]; then
        echo "  install state: not installed ❌"
        echo "    No hook will run. Fix: autoreviewer install"
    elif [ "$effective_abs" = "$our_hooks" ]; then
        if [ -n "$chained" ]; then
            echo "  install state: installed ✅ (chain mode → $chained)"
        elif [ -n "$local_hp" ]; then
            echo "  install state: installed ✅ (local core.hooksPath → $our_hooks)"
        else
            echo "  install state: inherited from global ✅"
        fi
    else
        # Effective hooksPath is something else (Husky / Lefthook / .githooks)
        # Check for legacy shim in that directory
        local legacy="$effective_abs/post-commit"
        if [ -f "$legacy" ] && grep -q "\.autoreviewer/hooks/post-commit" "$legacy" 2>/dev/null; then
            echo "  install state: installed (legacy shim) ⚠️"
            echo "    Found old-style shim: $legacy"
            echo "    Recommended: autoreviewer install --upgrade"
            echo "      (chain mode keeps your project's tracked files clean)"
        elif [ -n "$chained" ]; then
            # We were chain-installed before (chained_hooks_path saved), but
            # something overwrote core.hooksPath. Almost always `pod install`
            # on iOS repos. Self-heal would normally have fixed this already
            # — if we reach here it's because AUTOREVIEWER_NO_AUTOHEAL=1 or
            # the heal failed.
            echo "  install state: OVERWRITTEN ⚠️ (was installed, hooksPath got reset)"
            echo "    Saved chain: $chained"
            echo "    Current hooksPath: $effective_abs"
            echo "    Likely cause: \`pod install\` (or another tool) reset core.hooksPath."
            echo "    Fix: autoreviewer install   (re-applies chain mode)"
        else
            echo "  install state: NOT installed ⚠️"
            echo "    This repo's hooksPath = $effective_abs"
            echo "    Fix: autoreviewer install"
            echo "      (will switch to chain mode — no tracked files modified)"
        fi
    fi

    # Per-repo on/off (independent from install state)
    if ar_is_enabled "$repo"; then
        echo "  per-repo switch: ON  (autoreviewer disable --repo . to pause this repo)"
    else
        echo "  per-repo switch: OFF 🛑 (autoreviewer enable --repo .)"
    fi

    local count
    count=$(find "$(git rev-parse --git-dir)/reviews" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
    echo "  reviews:       $count stored"
}

# ---------- run ----------

cmd_run() {
    require_repo
    local mode="--sync"  # default sync for manual invocation
    local squash=0
    local args=()
    local extra=()
    while [ $# -gt 0 ]; do
        case "$1" in
            --async)     mode=""; shift ;;
            --sync)      mode="--sync"; shift ;;
            --squash)    squash=1; shift ;;
            --no-notify) extra+=("--no-notify"); shift ;;
            --open)      extra+=("--open"); shift ;;
            -h|--help)
                cat <<'EOF'
Usage: autoreviewer run [<commit>...] [--squash] [--async|--sync] [--no-notify] [--open]

  <commit>...   one or more commits or git rev-list specs.
                  examples:  HEAD            (default if none given)
                             abc123 def456   two specific commits
                             HEAD~3..HEAD    range — last 3 commits
                             main..feature   commits unique to feature
                no args → defaults to HEAD.

  --squash      review the entire span as ONE combined diff (PR-style).
                base = oldest^, tip = newest. Single .md is produced.
                Without --squash (default), each commit gets its own .md,
                consistent with the post-commit hook.

  --async       fire reviews in the background.
  --sync        wait for each to finish (default for manual run).
  --no-notify   suppress macOS notifications.
  --open        open the .md report when done.
EOF
                return 0 ;;
            -*) die "unknown option: $1" ;;
            *)  args+=("$1"); shift ;;
        esac
    done

    # No positional args → review HEAD only (matches old behavior).
    if [ "${#args[@]}" -eq 0 ]; then
        args=("HEAD")
    fi

    # Resolve every arg to one or more commit hashes:
    #   - 'a..b' / 'a...b' / 'a^!' → expand via git rev-list
    #   - single ref (HEAD, branch, hash, tag) → resolve via git rev-parse
    # Result `resolved` is in user-given order; for ranges, oldest first.
    local resolved=()
    local arg
    for arg in "${args[@]}"; do
        if [[ "$arg" == *..* ]] || [[ "$arg" == *^@ ]] || [[ "$arg" == *^! ]]; then
            # Range / set spec — expand
            local h
            local got=0
            while IFS= read -r h; do
                [ -n "$h" ] && resolved+=("$h") && got=1
            done < <(git rev-list --reverse "$arg" 2>/dev/null)
            [ "$got" = "0" ] && die "no commits matched: $arg"
        else
            local h
            h=$(git rev-parse --verify "$arg" 2>/dev/null) \
                || die "unknown commit: $arg"
            resolved+=("$h")
        fi
    done

    if [ "${#resolved[@]}" -eq 0 ]; then
        die "no commits to review (resolved list is empty)"
    fi

    local repo_root
    repo_root=$(git rev-parse --show-toplevel)
    local reviews_dir="$repo_root/.git/reviews"
    mkdir -p "$reviews_dir"

    if [ "$squash" = "1" ]; then
        # Squash: build ONE range covering oldest..newest and send to runner.py.
        # Two subtleties:
        #   1. User may pass commits out of order; sort by commit date so
        #      "oldest" is genuinely the oldest in the input set.
        #   2. If the oldest commit is a root commit (no parent), `oldest^`
        #      doesn't resolve. Fall back to the well-known empty-tree SHA
        #      (4b825dc...4904) so we still diff from "before history".
        #
        # Note on sort order: `--no-walk=sorted` sorts by COMMIT DATE
        # (newest first); `--reverse` flips to oldest first. This is NOT
        # topological order — for our use it's fine because oldest/newest
        # in a feature branch typically agree, but rebase/cherry-pick can
        # decouple them. If that becomes a problem, switch to
        # `--topo-order` (note: --no-walk + --topo-order is rejected by
        # git; you'd have to drop --no-walk and rely on input being a
        # range).
        local sorted=()
        local h
        while IFS= read -r h; do
            [ -n "$h" ] && sorted+=("$h")
        done < <(git rev-list --reverse --no-walk=sorted "${resolved[@]+${resolved[@]}}" 2>/dev/null)
        if [ "${#sorted[@]}" -eq 0 ]; then
            die "could not sort resolved commits"
        fi
        local last_idx=$((${#sorted[@]} - 1))
        local oldest="${sorted[0]}"
        local newest="${sorted[$last_idx]}"

        local range base_full
        if base_full=$(git rev-parse --verify "${oldest}^" 2>/dev/null); then
            range="${base_full}..${newest}"
        else
            # Empty tree SHA — universally present in every git repo.
            range="4b825dc642cb6eb9a060e54bf8d69288fbee4904..${newest}"
        fi

        local oldest_short newest_short
        oldest_short=$(git rev-parse --short "$oldest")
        newest_short=$(git rev-parse --short "$newest")
        local log_file="$reviews_dir/.last-run-${oldest_short}_to_${newest_short}.log"
        echo "🔄 squash review of ${#sorted[@]} commit(s): ${oldest_short} → ${newest_short}"
        _autoreviewer_run_one "$range" "$mode" "$repo_root" "$log_file" "${extra[@]+${extra[@]}}"
        if [ "$mode" != "--sync" ]; then
            echo "   started in background (log: $log_file)"
        fi
    else
        # Per-commit: run runner.py once per resolved commit, in order
        # (oldest first). With async, we still serialize via runner.py's
        # flock — but we kick them off immediately so the user sees one
        # "started" message per commit.
        local total=${#resolved[@]}
        local i=1
        local h
        local async_logs=()
        for h in "${resolved[@]}"; do
            local short
            short=$(git rev-parse --short "$h")
            echo "🔄 [$i/$total] reviewing $short"
            # Use a per-target log file so async fan-out doesn't truncate
            # earlier runners' output (each `> "$log_file"` redirect on
            # the same path would clobber the previous one).
            local log_file="$reviews_dir/.last-run-${short}.log"
            _autoreviewer_run_one "$h" "$mode" "$repo_root" "$log_file" "${extra[@]+${extra[@]}}"
            [ "$mode" != "--sync" ] && async_logs+=("$log_file")
            i=$((i + 1))
        done
        if [ "$mode" != "--sync" ]; then
            echo "   $total review(s) queued in background. Logs:"
            for h in "${async_logs[@]}"; do echo "     $h"; done
        fi
    fi
}

# Top-level helper (NOT nested inside cmd_run — bash functions are global,
# nesting a function definition just delays its global registration to the
# first time the outer is called and leaves it polluting the namespace
# afterwards). Takes all dependencies via explicit params for testability.
#
# Usage:
#   _autoreviewer_run_one <target> <mode> <repo_root> <log_file> [extra_args...]
#
# - target:    a commit hash, ref, or 'a..b' range to pass to runner.py
# - mode:      "--sync" for foreground; anything else (incl. "") for async
# - repo_root: absolute path to repo (cwd for the async subshell)
# - log_file:  where to redirect stdout+stderr in async mode
# - extra:     additional flags forwarded to runner.py (--no-notify, --open)
_autoreviewer_run_one() {
    local target="$1"
    local mode="$2"
    local repo_root="$3"
    local log_file="$4"
    shift 4

    if [ "$mode" = "--sync" ]; then
        python3 "$AUTOREVIEWER_HOME/lib/runner.py" "$target" --sync "$@"
    else
        (
            cd "$repo_root" || exit 1
            nohup python3 "$AUTOREVIEWER_HOME/lib/runner.py" "$target" "$@" \
                > "$log_file" 2>&1 &
            disown
        )
    fi
}

# ---------- log ----------

cmd_log() {
    require_repo
    local n=20
    local sev_filter=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -n) n="$2"; shift 2 ;;
            --severity) sev_filter="$2"; shift 2 ;;
            *) die "unknown option: $1" ;;
        esac
    done

    local index_file
    index_file="$(git rev-parse --git-dir)/reviews/index.json"
    if [ ! -f "$index_file" ]; then
        echo "No reviews yet."
        return 0
    fi

    printf '%-9s %-17s %-12s %-50s %s\n' "HASH" "DATE" "SEVERITY" "COMMIT" "ISSUES"

    local jq_filter='.[] | "\(.hash)|\(.date)|\(.severity)|\(.message)|\(.issue_count)"'
    if [ -n "$sev_filter" ]; then
        jq_filter='.[] | select(.severity == "'"$sev_filter"'") | "\(.hash)|\(.date)|\(.severity)|\(.message)|\(.issue_count)"'
    fi

    # Reverse with awk (portable across macOS/Linux), then take last n
    jq -r "$jq_filter" "$index_file" 2>/dev/null \
      | awk '{a[NR]=$0} END{for(i=NR;i>0;i--) print a[i]}' \
      | head -n "$n" \
      | while IFS='|' read -r hash date severity message issues; do
            local emoji
            # Keep in sync with SEVERITY_EMOJI in lib/runner.py.
            case "$severity" in
                high)   emoji="🔴" ;;
                medium) emoji="🟠" ;;
                low)    emoji="🟡" ;;
                ok)     emoji="🟢" ;;
                *)      emoji="⚪" ;;
            esac
            # Truncate ISO date to YYYY-MM-DD HH:MM
            date="${date:0:16}"
            date="${date/T/ }"
            printf '%-9s %-17s %s %-10s %-50.50s %s\n' "$hash" "$date" "$emoji" "$severity" "$message" "$issues"
        done
}

# ---------- show ----------

cmd_show() {
    require_repo
    local hash=""
    local open_it=0
    local json_mode=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --open) open_it=1; shift ;;
            --json) json_mode=1; shift ;;
            -*) die "unknown option: $1" ;;
            *) hash="$1"; shift ;;
        esac
    done

    local reviews_dir
    reviews_dir="$(git rev-parse --git-dir)/reviews"

    local file
    if [ -z "$hash" ]; then
        # Latest
        file=$(ls -t "$reviews_dir"/*.md 2>/dev/null | head -1)
    else
        file=$(ls -t "$reviews_dir"/*"${hash}"*.md 2>/dev/null | head -1)
    fi

    [ -z "$file" ] && die "no review found"

    if [ "$json_mode" = "1" ]; then
        cat "${file%.md}.json"
        return 0
    fi

    if [ "$open_it" = "1" ]; then
        open "$file"
        return 0
    fi

    if command -v glow >/dev/null 2>&1; then
        glow "$file"
    elif command -v bat >/dev/null 2>&1; then
        bat --style=plain --language=md "$file"
    else
        cat "$file"
    fi
}

# ---------- clean ----------

cmd_clean() {
    require_repo
    local mode=""
    local age=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --all) mode="all"; shift ;;
            --older-than) age="$2"; shift 2 ;;
            *) die "unknown option: $1" ;;
        esac
    done

    local reviews_dir
    reviews_dir="$(git rev-parse --git-dir)/reviews"
    [ ! -d "$reviews_dir" ] && { echo "Nothing to clean."; return 0; }

    if [ "$mode" = "all" ]; then
        echo "About to delete all reviews in: $reviews_dir"
        read -rp "Proceed? [y/N] " yn
        [ "$yn" = "y" ] || [ "$yn" = "Y" ] || { echo "Cancelled."; return 0; }
        rm -f "$reviews_dir"/*.{json,md,raw.txt} "$reviews_dir/index.json"
        echo "🧹 Cleaned."
    elif [ -n "$age" ]; then
        # parse "30d" / "7d"
        local days="${age%d}"
        [[ "$days" =~ ^[0-9]+$ ]] || die "invalid --older-than (use e.g. 30d)"
        find "$reviews_dir" -maxdepth 1 \( -name "*.md" -o -name "*.json" -o -name "*.raw.txt" \) -mtime +"$days" -print -delete
        echo "🧹 Cleaned files older than ${days}d."
    else
        die "specify --all or --older-than Xd"
    fi
}

# ---------- cancel ----------

cmd_cancel() {
    require_repo
    local pid_file
    pid_file="$(git rev-parse --git-dir)/reviews/.running.pid"
    if [ -f "$pid_file" ]; then
        local pid
        pid=$(cat "$pid_file")
        if kill "$pid" 2>/dev/null; then
            echo "🛑 Killed review process $pid"
            rm -f "$pid_file"
        else
            echo "Process $pid not running. Cleaning up stale pid file."
            rm -f "$pid_file"
        fi
    else
        echo "No review currently running."
    fi
}

# ---------- install (per-repo trigger) ----------

# Marker used to find/remove our trigger in third-party post-commit files
AR_MARKER_BEGIN="# >>> autoreviewer trigger >>>"
AR_MARKER_END="# <<< autoreviewer trigger <<<"

# Marker for the shell prompt hook block written into ~/.zshrc / ~/.bashrc.
# Version is encoded in the marker so future block-body changes can be
# detected and migrated. Bump AR_SHELL_HOOK_VERSION whenever the body
# inside the hook block changes meaningfully.
AR_SHELL_HOOK_VERSION="1"
AR_SHELL_HOOK_BEGIN="# >>> autoreviewer prompt hook (v${AR_SHELL_HOOK_VERSION}) >>>"
AR_SHELL_HOOK_END="# <<< autoreviewer prompt hook (v${AR_SHELL_HOOK_VERSION}) <<<"

# Regex prefixes used to detect ANY version (including pre-versioned blocks
# that lack the (vN) suffix). Used by install/uninstall/status so that:
#   - install: doesn't write a duplicate when an older block already exists
#   - uninstall: can clean up any historical version
#   - status:   can warn when an older version is present
AR_SHELL_HOOK_BEGIN_RE='^# >>> autoreviewer prompt hook'
AR_SHELL_HOOK_END_RE='^# <<< autoreviewer prompt hook'

# Marker for the PATH block written into ~/.zshrc / ~/.bashrc. Exists
# because the CLI is installed under ~/.local/bin which is NOT on macOS
# default PATH — without this block the user gets "command not found"
# even though autoreviewer is correctly installed.
AR_PATH_HOOK_VERSION="1"
AR_PATH_HOOK_BEGIN="# >>> autoreviewer PATH (v${AR_PATH_HOOK_VERSION}) >>>"
AR_PATH_HOOK_END="# <<< autoreviewer PATH (v${AR_PATH_HOOK_VERSION}) <<<"
AR_PATH_HOOK_BEGIN_RE='^# >>> autoreviewer PATH'
AR_PATH_HOOK_END_RE='^# <<< autoreviewer PATH'

cmd_install() {
    local repo=""
    local uninstall=0
    local upgrade=0
    local no_shell_hook=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --repo) repo="$2"; shift 2 ;;
            --uninstall) uninstall=1; shift ;;
            --upgrade) upgrade=1; shift ;;
            --no-shell-hook) no_shell_hook=1; shift ;;
            -h|--help)
                echo "Usage: autoreviewer install [--repo PATH] [--uninstall|--upgrade] [--no-shell-hook]"
                echo ""
                echo "Enables autoreviewer for one git repo (the canonical workflow)."
                echo ""
                echo "Two cases handled automatically:"
                echo "  1. Vanilla repo (no local core.hooksPath):"
                echo "       sets local core.hooksPath = ~/.autoreviewer/hooks"
                echo "  2. Repo overrides core.hooksPath (Husky / Lefthook / project .githooks):"
                echo "       saves chained_hooks_path to .git/autoreviewer.json (chain mode)"
                echo ""
                echo "Also installs a shell prompt hook (~/.zshrc or ~/.bashrc) so that"
                echo "core.hooksPath is auto-restored after any tool overwrites it"
                echo "(pod install, npm install, etc.). Use --no-shell-hook to skip."
                echo ""
                echo "--uninstall reverses the per-repo change. Shell hook is left in"
                echo "place (it benefits other repos); remove with"
                echo "'autoreviewer shell-hook uninstall'."
                return 0 ;;
            *) die "unknown option: $1" ;;
        esac
    done

    if [ -n "$repo" ]; then
        cd "$repo" || die "cannot cd to $repo"
    fi
    require_repo

    local repo_root our_hooks
    repo_root=$(git rev-parse --show-toplevel)
    our_hooks="$AUTOREVIEWER_HOME/hooks"

    # Read both local and effective hooksPath
    local local_hp effective
    local_hp=$(git config --local --get core.hooksPath 2>/dev/null || echo "")
    effective=$(git config --get core.hooksPath 2>/dev/null || echo "")

    # Resolve effective to absolute for safe comparison
    local effective_abs="$effective"
    if [ -n "$effective" ] && [[ "$effective" != /* ]]; then
        effective_abs="$repo_root/$effective"
    fi
    effective_abs="${effective_abs%/}"
    local our_hooks_norm="${our_hooks%/}"

    # Read chained_hooks_path from .git/autoreviewer.json if present —
    # this is the authoritative signal that we're in chain mode (Case A).
    local repo_git_dir repo_cfg saved_chain
    repo_git_dir=$(git rev-parse --absolute-git-dir)
    repo_cfg="$repo_git_dir/autoreviewer.json"
    saved_chain=""
    if [ -f "$repo_cfg" ]; then
        saved_chain=$(jq -r '.chained_hooks_path // empty' "$repo_cfg" 2>/dev/null)
    fi

    # ---------- Case A: chain mode (already installed OR will install via chain) ----------
    # Trigger Case A if EITHER:
    #   (a) we already saved a chained_hooks_path (i.e. we previously installed via chain)
    #   (b) the repo overrides hooksPath to something other than us
    if [ -n "$saved_chain" ] || ([ -n "$local_hp" ] && [ "$effective_abs" != "$our_hooks_norm" ]); then
        # Determine the original_hp: either the saved chain or the current local_hp
        local original_hp="${saved_chain:-$local_hp}"

        if [ "$uninstall" = "1" ]; then
            _ar_chain_uninstall "$repo_root"
            return 0
        fi
        if [ "$upgrade" = "1" ]; then
            _ar_chain_upgrade "$repo_root" "$original_hp"
            return 0
        fi

        # First-time install: warn about leftover legacy shim
        local override_abs="$original_hp"
        if [[ "$override_abs" != /* ]]; then
            override_abs="$repo_root/$override_abs"
        fi
        local legacy_shim="$override_abs/post-commit"
        if [ -z "$saved_chain" ] && [ -f "$legacy_shim" ] && grep -q "\.autoreviewer/hooks/post-commit" "$legacy_shim" 2>/dev/null; then
            echo "⚠️  Detected a legacy autoreviewer shim from an older version:"
            echo "     $legacy_shim"
            echo "   Run: autoreviewer install --upgrade   to migrate cleanly."
            return 1
        fi

        _ar_chain_install "$repo_root" "$original_hp"
        if [ "$no_shell_hook" != "1" ]; then
            _ar_shell_hook_install
        fi
        return 0
    fi

    # ---------- Case B: vanilla repo (we set local hooksPath ourselves) ----------
    if [ "$uninstall" = "1" ]; then
        if [ "$effective_abs" = "$our_hooks_norm" ] && [ -n "$local_hp" ]; then
            git config --local --unset core.hooksPath
            ar_repo_unregister "$repo_root"
            echo "🧹 unset local core.hooksPath (autoreviewer disabled for this repo)"
        else
            echo "ℹ️  Nothing to remove — repo isn't using our local hooksPath."
        fi
        return 0
    fi

    if [ "$effective_abs" = "$our_hooks_norm" ]; then
        echo "✅ already installed (local core.hooksPath → $our_hooks)"
        ar_repo_register "$repo_root"   # idempotent backfill
        if [ "$no_shell_hook" != "1" ]; then
            _ar_shell_hook_install
        fi
        return 0
    fi

    # Set it
    git config --local core.hooksPath "$our_hooks"
    ar_repo_register "$repo_root"
    echo "✅ installed for repo: $repo_root"
    echo "   set local core.hooksPath = $our_hooks"
    if [ "$no_shell_hook" != "1" ]; then
        _ar_shell_hook_install
    fi
    echo ""
    echo "Test it:"
    echo "  git commit --allow-empty -m 'test: autoreviewer'"
}

# ---------- new chain-based helpers (no tracked-file modifications) ----------

# Save chained hooks path to <repo>/.git/autoreviewer.json and switch local
# core.hooksPath to ours.
# Args: <repo_root> <original_hooks_path>
_ar_chain_install() {
    local repo_root="$1"
    local original_hp="$2"
    local our_hooks="$AUTOREVIEWER_HOME/hooks"
    local git_dir cfg
    git_dir=$(cd "$repo_root" && git rev-parse --absolute-git-dir)
    cfg="$git_dir/autoreviewer.json"

    # Idempotency: if already pointing at us AND chained_hooks_path saved, done
    local effective
    effective=$(cd "$repo_root" && git config --local --get core.hooksPath 2>/dev/null || echo "")
    if [ "$effective" = "$our_hooks" ]; then
        local existing_chain
        if [ -f "$cfg" ]; then
            existing_chain=$(jq -r '.chained_hooks_path // empty' "$cfg" 2>/dev/null)
        fi
        if [ -n "$existing_chain" ]; then
            echo "✅ already installed (chain → $existing_chain)"
            ar_repo_register "$repo_root"   # idempotent; backfills registry
            return 0
        fi
    fi

    # Save original hooks path
    if [ ! -f "$cfg" ]; then
        echo "{}" > "$cfg"
    fi
    local tmp
    tmp=$(mktemp)
    jq --arg p "$original_hp" '.chained_hooks_path = $p' "$cfg" > "$tmp" && mv "$tmp" "$cfg"

    # Switch local hooksPath to ours
    (cd "$repo_root" && git config --local core.hooksPath "$our_hooks")

    # Register in the prompt-hook fast-path registry
    ar_repo_register "$repo_root"

    echo "✅ installed (chain mode)"
    echo "   chained_hooks_path = $original_hp  (saved to .git/autoreviewer.json)"
    echo "   local core.hooksPath = $our_hooks"
    echo ""
    echo "   Project hooks (commit-msg, pre-push, ...) still fire via _chain shim."
    echo "   No tracked files in your repo were modified."
    echo ""
    echo "Test it:"
    echo "  cd $repo_root && git commit --allow-empty -m 'test: autoreviewer'"
}

# Restore the original local hooksPath; remove chained_hooks_path entry.
_ar_chain_uninstall() {
    local repo_root="$1"
    local git_dir cfg
    git_dir=$(cd "$repo_root" && git rev-parse --absolute-git-dir)
    cfg="$git_dir/autoreviewer.json"

    local saved=""
    if [ -f "$cfg" ]; then
        saved=$(jq -r '.chained_hooks_path // empty' "$cfg" 2>/dev/null)
    fi

    if [ -z "$saved" ]; then
        echo "ℹ️  No saved chained_hooks_path — nothing to restore here."
        echo "   If this repo's effective hooksPath is autoreviewer's, manually run:"
        echo "     git config --local --unset core.hooksPath"
        return 0
    fi

    (cd "$repo_root" && git config --local core.hooksPath "$saved")
    # Remove the key but keep the file (other autoreviewer settings may live there)
    local tmp
    tmp=$(mktemp)
    jq 'del(.chained_hooks_path)' "$cfg" > "$tmp" && mv "$tmp" "$cfg"

    # Drop from the prompt-hook fast-path registry
    ar_repo_unregister "$repo_root"

    echo "🧹 restored local core.hooksPath = $saved"
    echo "   removed chained_hooks_path from .git/autoreviewer.json"
}

# Migrate from the old design (which wrote a shim into the override dir) to
# the new chain design.
_ar_chain_upgrade() {
    local repo_root="$1"
    local original_hp="$2"
    local override_abs="$original_hp"
    if [[ "$override_abs" != /* ]]; then
        override_abs="$repo_root/$override_abs"
    fi
    local legacy_shim="$override_abs/post-commit"

    echo "Upgrading repo to chain-mode autoreviewer install..."

    # 1. If legacy shim exists, deal with it
    if [ -f "$legacy_shim" ]; then
        # Check if file is tracked in git — warn the user
        local tracked=""
        if (cd "$repo_root" && git ls-files --error-unmatch "$override_abs/post-commit" >/dev/null 2>&1); then
            tracked="yes"
        fi

        # Backup
        local bak="$legacy_shim.bak.$(date +%s)"
        cp "$legacy_shim" "$bak"
        echo "ℹ️  backed up legacy shim: $bak"

        if grep -q "$AR_MARKER_BEGIN" "$legacy_shim" 2>/dev/null; then
            # Marker-wrapped shim → strip block
            local tmp
            tmp=$(mktemp)
            awk -v b="$AR_MARKER_BEGIN" -v e="$AR_MARKER_END" '
                $0 == b { skip=1; next }
                $0 == e { skip=0; next }
                !skip
            ' "$legacy_shim" > "$tmp"
            awk 'NF{p=1} p' "$tmp" > "$legacy_shim"
            rm -f "$tmp"
        elif grep -q "\.autoreviewer/hooks/post-commit" "$legacy_shim" 2>/dev/null; then
            # Legacy plain shim → strip the trigger lines
            local tmp
            tmp=$(mktemp)
            awk '
                /\.autoreviewer\/hooks\/post-commit/ { next }
                /autoreviewer trigger \(managed by autoreviewer install\)/ { next }
                { print }
            ' "$legacy_shim" > "$tmp"
            awk 'NF{p=1} p' "$tmp" > "$legacy_shim"
            rm -f "$tmp"
        fi

        # If the file is now essentially empty (just shebang or empty), delete it
        local non_blank
        non_blank=$(grep -cv '^\s*$' "$legacy_shim" 2>/dev/null || echo 0)
        if [ "$non_blank" -le 1 ] && head -1 "$legacy_shim" 2>/dev/null | grep -q '^#!'; then
            rm -f "$legacy_shim"
            echo "🧹 removed (was only autoreviewer trigger): $legacy_shim"
        else
            echo "🧹 removed autoreviewer trigger from: $legacy_shim"
        fi

        if [ "$tracked" = "yes" ]; then
            echo ""
            echo "⚠️  WARNING: $legacy_shim is TRACKED IN GIT."
            echo "   The cleanup above only changed your working copy."
            echo "   Please review with: git diff $legacy_shim"
            echo "   …and commit the removal so other team members aren't affected."
        fi
    else
        echo "ℹ️  no legacy shim file found at $legacy_shim — proceeding to chain install"
    fi

    # 2. Install in new chain mode
    _ar_chain_install "$repo_root" "$original_hp"
}

# ---------- heal (idempotent self-fix; called by shell prompt hook) ----------

cmd_heal() {
    if command -v ar_self_heal_if_needed >/dev/null 2>&1; then
        ar_self_heal_if_needed
    fi
}

# ---------- shell prompt hook ----------
# Writes a precmd_functions (zsh) or PROMPT_COMMAND (bash) snippet that runs
# `autoreviewer heal` after every command — but ONLY when $PWD is inside a
# repo registered in ~/.autoreviewer/repos. The registry check is pure
# shell (no fork), so prompts outside any registered repo cost ~1ms.
#
# We install in BOTH ~/.zshrc and ~/.bash_profile/.bashrc (whichever
# exist) so multi-shell users get coverage regardless of $SHELL.

# Print the primary rc file (the one matching $SHELL). Used only to tell
# users which file to source after install. Returns 1 for unknown shells.
_ar_shell_primary_rc() {
    case "${SHELL##*/}" in
        zsh)  echo "$HOME/.zshrc" ;;
        bash)
            if [ -f "$HOME/.bash_profile" ]; then
                echo "$HOME/.bash_profile"
            else
                echo "$HOME/.bashrc"
            fi
            ;;
        *) return 1 ;;
    esac
}

# Emit the shell hook block for the given shell kind (zsh|bash) on stdout.
# Uses 'EOF' (quoted) heredoc so nothing inside is expanded — the snippet
# is written to the rc file verbatim and only evaluated when the shell
# starts. Markers go through echo so the script doesn't have to manually
# escape $vars in the body.
_ar_shell_hook_block() {
    local kind="$1"
    echo "$AR_SHELL_HOOK_BEGIN"
    case "$kind" in
        zsh)
            cat <<'EOF'
# Auto-heal git core.hooksPath after every command, but only when in a
# registered autoreviewer repo. Pure-shell registry check first — if PWD
# is not inside any registered repo, return immediately without forking.
# Covers any tool that overrides core.hooksPath (pod install, npm install,
# husky install, gradle, manual 'git config' edits).
# Remove with: autoreviewer shell-hook uninstall
__autoreviewer_precmd() {
    local registry="${AUTOREVIEWER_HOME:-$HOME/.autoreviewer}/repos"
    [[ -f "$registry" ]] || return
    local r
    while IFS= read -r r; do
        [[ -z "$r" ]] && continue
        case "$PWD" in
            "$r"|"$r"/*)
                command -v autoreviewer >/dev/null 2>&1 && autoreviewer heal 2>/dev/null
                return
                ;;
        esac
    done < "$registry"
}
typeset -g -a precmd_functions
[[ -z ${precmd_functions[(r)__autoreviewer_precmd]:-} ]] && precmd_functions+=(__autoreviewer_precmd)
EOF
            ;;
        bash)
            cat <<'EOF'
# Auto-heal git core.hooksPath after every command. Same fast-path
# strategy as the zsh equivalent — see comments there.
# Remove with: autoreviewer shell-hook uninstall
__autoreviewer_precmd() {
    local registry="${AUTOREVIEWER_HOME:-$HOME/.autoreviewer}/repos"
    [ -f "$registry" ] || return 0
    local r
    while IFS= read -r r; do
        [ -z "$r" ] && continue
        case "$PWD" in
            "$r"|"$r"/*)
                command -v autoreviewer >/dev/null 2>&1 && autoreviewer heal 2>/dev/null
                return 0
                ;;
        esac
    done < "$registry"
}
case ";${PROMPT_COMMAND:-};" in
    *";__autoreviewer_precmd;"*) ;;
    *) PROMPT_COMMAND="__autoreviewer_precmd;${PROMPT_COMMAND:-}" ;;
esac
EOF
            ;;
    esac
    echo "$AR_SHELL_HOOK_END"
}

# Return the list of rc files we want to write to: ~/.zshrc and one of
# {~/.bash_profile, ~/.bashrc}. Skips files for shells the user clearly
# doesn't have (rc file doesn't exist) UNLESS it's the primary rc for
# the user's $SHELL — in that case we'll create it.
#
# install paths use this (smart subset). uninstall/status paths use
# _ar_shell_all_known_rcs (full union) so we always clean up everything
# we may have written historically — even if the smart-subset logic
# changes later.
_ar_shell_target_rcs() {
    local primary
    primary=$(_ar_shell_primary_rc 2>/dev/null) || primary=""

    # zsh
    if [ -f "$HOME/.zshrc" ] || [ "$primary" = "$HOME/.zshrc" ]; then
        echo "$HOME/.zshrc"
    fi
    # bash — prefer .bash_profile if it exists, else .bashrc
    if [ -f "$HOME/.bash_profile" ]; then
        echo "$HOME/.bash_profile"
    elif [ -f "$HOME/.bashrc" ] || [ "$primary" = "$HOME/.bashrc" ] || [ "$primary" = "$HOME/.bash_profile" ]; then
        echo "$HOME/.bashrc"
    fi
}

# Canonical full list of rc files we have EVER written to. Used by
# uninstall and status_line in both shell-hook and path-hook so the
# cleanup surface stays in sync as _ar_shell_target_rcs evolves.
# Append-only — never remove entries from this list, only add (so a
# user who upgraded across versions still gets cleaned up).
_ar_shell_all_known_rcs() {
    echo "$HOME/.zshrc"
    echo "$HOME/.bash_profile"
    echo "$HOME/.bashrc"
}

# Idempotent install across all relevant rc files.
_ar_shell_hook_install() {
    local primary
    if ! primary=$(_ar_shell_primary_rc); then
        echo "⚠️  shell hook: unknown shell ($SHELL); skipped" >&2
        echo "   Manual install: append the hook block to your shell rc." >&2
        return 0
    fi

    [ -f "$primary" ] || touch "$primary"

    local installed=0
    local outdated=0
    local outdated_files=""
    local rc
    while IFS= read -r rc; do
        [ -z "$rc" ] && continue
        # If file has any version of our marker, don't write again — that
        # would create a duplicate block. If the marker is the CURRENT
        # version, this is a no-op (idempotent install). If it's an older
        # version, mark it for the end-of-loop summary so we print the
        # upgrade hint exactly once even when multiple rcs are outdated.
        if grep -qE -- "$AR_SHELL_HOOK_BEGIN_RE" "$rc" 2>/dev/null; then
            if ! grep -qF -- "$AR_SHELL_HOOK_BEGIN" "$rc" 2>/dev/null; then
                outdated=$((outdated + 1))
                outdated_files="${outdated_files:+$outdated_files, }$rc"
            fi
            continue
        fi
        # Pick block flavor based on filename
        local kind
        case "$rc" in
            *.zshrc) kind=zsh ;;
            *.bash_profile|*.bashrc) kind=bash ;;
            *) continue ;;
        esac
        {
            echo ""
            _ar_shell_hook_block "$kind"
        } >> "$rc"
        echo "✅ added prompt hook to $rc"
        installed=$((installed + 1))
    done < <(_ar_shell_target_rcs)

    if [ "$installed" -gt 0 ]; then
        echo "   activate now: source $primary   (or open a new terminal)"
    fi
    if [ "$outdated" -gt 0 ]; then
        echo "ℹ️  older prompt hook block(s) detected in: $outdated_files"
        echo "   To upgrade to v${AR_SHELL_HOOK_VERSION}, run:"
        echo "     autoreviewer shell-hook uninstall && autoreviewer shell-hook install"
    fi
}

# Remove any version of our marker block from every rc file that has one.
# Uses regex prefix match so that pre-versioned blocks (no (vN) suffix) are
# also cleaned. The awk strips between matched BEGIN/END regex pairs.
#
# Walks _ar_shell_all_known_rcs (NOT _ar_shell_target_rcs) so cleanup
# covers any historical write target even if install logic narrows.
_ar_shell_hook_uninstall() {
    local removed=0
    local rc
    while IFS= read -r rc; do
        [ -f "$rc" ] || continue
        if ! grep -qE -- "$AR_SHELL_HOOK_BEGIN_RE" "$rc" 2>/dev/null; then
            continue
        fi
        # Sanity: count BEGINs and ENDs. If unbalanced, refuse to write —
        # we don't want a stray BEGIN comment in the middle of the file
        # to cause us to wipe everything after it.
        #
        # Note on `|| true`: grep -c prints "0" on no-match but exits 1.
        # We use `|| true` (not `|| echo 0`) to avoid getting "0\n0" in
        # the captured value, which would break the numeric comparison.
        # Whitespace stripping is defensive against grep variants that
        # might emit leading/trailing whitespace on -c output.
        local begins ends
        begins=$(grep -cE -- "$AR_SHELL_HOOK_BEGIN_RE" "$rc" 2>/dev/null || true)
        ends=$(grep -cE -- "$AR_SHELL_HOOK_END_RE" "$rc" 2>/dev/null || true)
        begins=${begins//[[:space:]]/}
        ends=${ends//[[:space:]]/}
        if [ "${begins:-0}" -ne "${ends:-0}" ]; then
            echo "⚠️  $rc has ${begins:-0} BEGIN markers but ${ends:-0} END markers — refusing to edit." >&2
            echo "   Please clean it up manually, then re-run this command." >&2
            continue
        fi
        local tmp
        tmp=$(mktemp) || continue
        # Pass the regex prefixes via -v so the awk script and the shell
        # constants stay in sync — bumping AR_SHELL_HOOK_BEGIN_RE doesn't
        # require a parallel edit here.
        awk -v b="$AR_SHELL_HOOK_BEGIN_RE" -v e="$AR_SHELL_HOOK_END_RE" '
            $0 ~ b { skip=1; next }
            $0 ~ e { skip=0; next }
            !skip
        ' "$rc" > "$tmp" && mv "$tmp" "$rc"
        echo "🧹 removed prompt hook from $rc"
        removed=$((removed + 1))
    done < <(_ar_shell_all_known_rcs)
    if [ "$removed" -eq 0 ]; then
        echo "ℹ️  prompt hook not present in any shell rc — nothing to remove."
    else
        echo "   open a new terminal (or restart your shell) to fully apply"
    fi
}

_ar_shell_hook_status_line() {
    local current="" outdated=""
    local rc
    while IFS= read -r rc; do
        [ -f "$rc" ] || continue
        if grep -qF -- "$AR_SHELL_HOOK_BEGIN" "$rc" 2>/dev/null; then
            current="${current:+$current, }$rc"
        elif grep -qE -- "$AR_SHELL_HOOK_BEGIN_RE" "$rc" 2>/dev/null; then
            outdated="${outdated:+$outdated, }$rc"
        fi
    done < <(_ar_shell_all_known_rcs)
    if [ -z "$current" ] && [ -z "$outdated" ]; then
        local primary
        primary=$(_ar_shell_primary_rc 2>/dev/null) || primary="(unknown shell: $SHELL)"
        echo "not installed (target: $primary)"
    elif [ -n "$current" ] && [ -z "$outdated" ]; then
        echo "installed in $current ✅ (v${AR_SHELL_HOOK_VERSION})"
    elif [ -z "$current" ] && [ -n "$outdated" ]; then
        echo "OUTDATED in $outdated ⚠️  (run: autoreviewer shell-hook uninstall && autoreviewer shell-hook install)"
    else
        echo "mixed ⚠️  current=$current, OUTDATED=$outdated (run: autoreviewer shell-hook uninstall && autoreviewer shell-hook install)"
    fi
}

cmd_shell_hook() {
    local sub="${1:-status}"
    case "$sub" in
        install)   _ar_shell_hook_install ;;
        uninstall) _ar_shell_hook_uninstall ;;
        status)
            echo "Shell hook: $(_ar_shell_hook_status_line)"
            ;;
        -h|--help|help)
            cat <<'EOF'
Usage: autoreviewer shell-hook <install|uninstall|status>

The shell hook adds a precmd_functions (zsh) or PROMPT_COMMAND (bash) entry
to your shell rc that runs 'autoreviewer heal' after every command. Heal is
a 3ms no-op when nothing is wrong; it self-fixes core.hooksPath when a tool
(pod install / npm install / manual git config / etc.) has overwritten it.

`autoreviewer install` calls 'shell-hook install' automatically the first
time, unless --no-shell-hook is passed.
EOF
            ;;
        *) die "unknown subcommand: $sub (try: install|uninstall|status)" ;;
    esac
}

# ---------- PATH hook (ensure CLI is findable from interactive shells) ----------

# Emit the PATH block on stdout. Argument: the absolute bin dir to add.
# If bin_dir lives under $HOME, write it as "$HOME/relative/path" so the
# block is portable across machines that share the same rc file.
_ar_path_hook_block() {
    local bin_dir="$1"
    local rc_path="$bin_dir"
    # Use case rather than `[ "${bin_dir#$HOME/}" != "$bin_dir" ]` so that
    # $HOME with spaces or special chars doesn't break the prefix check.
    case "$bin_dir" in
        "$HOME"/*)
            rc_path="\$HOME/${bin_dir#"$HOME"/}"
            ;;
    esac
    echo "$AR_PATH_HOOK_BEGIN"
    cat <<EOF
# Added by 'autoreviewer install' so the autoreviewer CLI is findable in
# interactive shells. The inner case-statement guards against double-add
# (running this block twice does not duplicate the PATH entry).
# Remove with: autoreviewer path-hook uninstall
case ":\$PATH:" in
    *":$rc_path:"*) ;;
    *) export PATH="$rc_path:\$PATH" ;;
esac
EOF
    echo "$AR_PATH_HOOK_END"
}

# Install the PATH block in all relevant shell rc files. Idempotent.
# Argument: bin dir to add (defaults to $HOME/.local/bin).
_ar_path_hook_install() {
    local bin_dir="${1:-$HOME/.local/bin}"
    local primary
    primary=$(_ar_shell_primary_rc 2>/dev/null) || primary=""
    [ -n "$primary" ] && [ ! -f "$primary" ] && touch "$primary"

    local installed=0
    local rc
    while IFS= read -r rc; do
        [ -z "$rc" ] && continue
        if grep -qE -- "$AR_PATH_HOOK_BEGIN_RE" "$rc" 2>/dev/null; then
            continue   # any version already present — leave it (idempotent)
        fi
        {
            echo ""
            _ar_path_hook_block "$bin_dir"
        } >> "$rc"
        echo "✅ added PATH entry to $rc"
        installed=$((installed + 1))
    done < <(_ar_shell_target_rcs)

    if [ "$installed" -gt 0 ] && [ -n "$primary" ]; then
        echo "   activate now: source $primary   (or open a new terminal)"
    fi
}

# Remove the PATH block from every rc file that has one. Same balance-check
# pattern as shell-hook uninstall, so a stray BEGIN comment can't cause us
# to wipe everything below it.
#
# Walks _ar_shell_all_known_rcs to stay in lockstep with shell-hook uninstall
# (rather than maintaining a parallel hardcoded list that could drift).
_ar_path_hook_uninstall() {
    local removed=0
    local rc
    while IFS= read -r rc; do
        [ -f "$rc" ] || continue
        if ! grep -qE -- "$AR_PATH_HOOK_BEGIN_RE" "$rc" 2>/dev/null; then
            continue
        fi
        local begins ends
        begins=$(grep -cE -- "$AR_PATH_HOOK_BEGIN_RE" "$rc" 2>/dev/null || true)
        ends=$(grep -cE -- "$AR_PATH_HOOK_END_RE" "$rc" 2>/dev/null || true)
        begins=${begins//[[:space:]]/}
        ends=${ends//[[:space:]]/}
        if [ "${begins:-0}" -ne "${ends:-0}" ]; then
            echo "⚠️  $rc has ${begins:-0} PATH BEGIN markers but ${ends:-0} END markers — refusing to edit." >&2
            continue
        fi
        local tmp
        tmp=$(mktemp) || continue
        awk -v b="$AR_PATH_HOOK_BEGIN_RE" -v e="$AR_PATH_HOOK_END_RE" '
            $0 ~ b { skip=1; next }
            $0 ~ e { skip=0; next }
            !skip
        ' "$rc" > "$tmp" && mv "$tmp" "$rc"
        echo "🧹 removed PATH entry from $rc"
        removed=$((removed + 1))
    done < <(_ar_shell_all_known_rcs)
}

_ar_path_hook_status_line() {
    local found=""
    local rc
    while IFS= read -r rc; do
        if [ -f "$rc" ] && grep -qE -- "$AR_PATH_HOOK_BEGIN_RE" "$rc" 2>/dev/null; then
            found="${found:+$found, }$rc"
        fi
    done < <(_ar_shell_all_known_rcs)
    if [ -z "$found" ]; then
        # Also check whether $BIN_DIR is currently in PATH — the block being
        # absent doesn't necessarily mean PATH is broken (the user may have
        # set it themselves elsewhere).
        local bin_dir="${HOME}/.local/bin"
        if echo "$PATH" | tr ':' '\n' | grep -qx "$bin_dir"; then
            echo "not installed (but $bin_dir is already on PATH ✅)"
        else
            echo "not installed ⚠️  ($bin_dir is NOT on PATH — autoreviewer command may be unfindable)"
        fi
    else
        echo "installed in $found ✅"
    fi
}

cmd_path_hook() {
    local sub="${1:-status}"
    shift 2>/dev/null || true
    case "$sub" in
        install)
            local bin_dir="${1:-$HOME/.local/bin}"
            _ar_path_hook_install "$bin_dir"
            ;;
        uninstall) _ar_path_hook_uninstall ;;
        status)    echo "PATH hook: $(_ar_path_hook_status_line)" ;;
        -h|--help|help)
            cat <<'EOF'
Usage: autoreviewer path-hook <install [bin_dir]|uninstall|status>

Manages a small `export PATH=...` block in your ~/.zshrc / ~/.bashrc that
adds the autoreviewer CLI directory to PATH. Idempotent — uses a marker
block, so reinstall is a no-op. Removed automatically on
'autoreviewer uninstall'.
EOF
            ;;
        *) die "unknown subcommand: $sub (try: install|uninstall|status)" ;;
    esac
}

# ---------- config (read/write JSON config without hand-editing) ----------

# Resolve the target config file based on whether --repo was given.
# Args: <repo_path_or_empty>
# Stdout: absolute path to the JSON file (creating dirs as needed is the
# caller's responsibility — this just resolves).
# Side effect (subshell-safe): cd's into repo for git rev-parse, but only
# inside this function's call so the caller's PWD is unaffected.
_ar_config_target_file() {
    local repo="$1"
    if [ -n "$repo" ]; then
        cd "$repo" 2>/dev/null || die "cannot cd to $repo"
        local git_dir
        git_dir=$(git rev-parse --absolute-git-dir 2>/dev/null) \
            || die "not a git repository: $repo"
        echo "$git_dir/autoreviewer.json"
    else
        echo "$GLOBAL_CONFIG"
    fi
}

_ar_config_cmd_get() {
    local key="" repo=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --repo) repo="$2"; shift 2 ;;
            -*) die "unknown option: $1" ;;
            *) key="$1"; shift ;;
        esac
    done
    [ -z "$key" ] && die "usage: autoreviewer config get <key> [--repo PATH]"

    local file
    file=$(_ar_config_target_file "$repo")
    if [ ! -f "$file" ]; then
        return 0   # silent for missing — caller can detect via empty stdout
    fi
    # Output the value as JSON-encoded (so numbers/bools come back faithfully).
    # Strings get printed without quotes for shell-friendliness.
    jq -r --arg k "$key" '
        if has($k) then
            (.[$k] | if type == "string" then . else tojson end)
        else
            empty
        end
    ' "$file"
}

_ar_config_cmd_set() {
    local key="" value="" got_value=0 repo=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --repo) repo="$2"; shift 2 ;;
            -*) die "unknown option: $1" ;;
            *)
                if [ -z "$key" ]; then
                    key="$1"
                elif [ "$got_value" = "0" ]; then
                    value="$1"
                    got_value=1
                else
                    die "unexpected extra argument: $1"
                fi
                shift ;;
        esac
    done
    [ -z "$key" ] && die "usage: autoreviewer config set <key> <value> [--repo PATH]"
    [ "$got_value" = "0" ] && die "usage: autoreviewer config set <key> <value> [--repo PATH]"

    local file
    file=$(_ar_config_target_file "$repo")
    mkdir -p "$(dirname "$file")"
    [ -f "$file" ] || echo "{}" > "$file"

    local tmp
    tmp=$(mktemp) || die "mktemp failed"

    # Decide whether VALUE is a JSON literal (600, true, null, "x") or a
    # bare string (claude). Use `jq empty` which only checks parse
    # validity and ignores the value itself — `jq -e .` would falsely
    # reject literal `false`/`null` because -e flags those as failure.
    if printf '%s' "$value" | jq empty >/dev/null 2>&1; then
        # Pass via --argjson so 600 stays a number, true/false stay bools, etc.
        if ! jq --arg k "$key" --argjson v "$value" '.[$k] = $v' "$file" > "$tmp"; then
            rm -f "$tmp"; die "jq failed (set $key = $value)"
        fi
    else
        if ! jq --arg k "$key" --arg v "$value" '.[$k] = $v' "$file" > "$tmp"; then
            rm -f "$tmp"; die "jq failed (set $key = $value)"
        fi
    fi
    mv "$tmp" "$file"

    # Echo back the stored value so user can verify type.
    local stored
    stored=$(jq -c --arg k "$key" '.[$k]' "$file")
    echo "✅ set $key = $stored  in $file"
}

_ar_config_cmd_unset() {
    local key="" repo=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --repo) repo="$2"; shift 2 ;;
            -*) die "unknown option: $1" ;;
            *) key="$1"; shift ;;
        esac
    done
    [ -z "$key" ] && die "usage: autoreviewer config unset <key> [--repo PATH]"

    local file
    file=$(_ar_config_target_file "$repo")
    if [ ! -f "$file" ]; then
        echo "ℹ️  $file does not exist — nothing to unset."
        return 0
    fi
    local tmp
    tmp=$(mktemp) || die "mktemp failed"
    if ! jq --arg k "$key" 'del(.[$k])' "$file" > "$tmp"; then
        rm -f "$tmp"; die "jq failed (unset $key)"
    fi
    mv "$tmp" "$file"
    echo "🧹 unset $key in $file"
}

_ar_config_cmd_list() {
    local repo=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --repo) repo="$2"; shift 2 ;;
            -*) die "unknown option: $1" ;;
            *) die "unknown arg: $1" ;;
        esac
    done

    local file
    file=$(_ar_config_target_file "$repo")
    if [ -f "$file" ]; then
        echo "# $file"
        jq . "$file"
    else
        echo "# $file"
        echo "(does not exist — using built-in defaults)"
    fi
}

cmd_config() {
    local sub="${1:-list}"
    shift 2>/dev/null || true
    case "$sub" in
        get)    _ar_config_cmd_get "$@" ;;
        set)    _ar_config_cmd_set "$@" ;;
        unset)  _ar_config_cmd_unset "$@" ;;
        list)   _ar_config_cmd_list "$@" ;;
        -h|--help|help)
            cat <<'EOF'
Usage:
  autoreviewer config list [--repo PATH]
  autoreviewer config get <key> [--repo PATH]
  autoreviewer config set <key> <value> [--repo PATH]
  autoreviewer config unset <key> [--repo PATH]

Without --repo, edits the GLOBAL config at ~/.autoreviewer/config.json.
With --repo, edits the per-repo override at <repo>/.git/autoreviewer.json
(per-repo values override global on a key-by-key basis).

VALUE is parsed as JSON when valid (so 600 → number, true → bool, "x" →
string). Bare strings without quotes are also accepted as strings, e.g.
  autoreviewer config set command claude

Common keys (defaults shown):
  timeout_seconds   600         seconds before review command is killed
  command           claude      the review tool to invoke
  command_args      ["-p"]      extra argv appended to command
  notification      terminal-notifier   terminal-notifier | osascript | none
  notify_threshold  low         minimum severity for completion notification
  notify_start      true        fire a "started" notification on commit
  language          zh          report language: zh | en
  auto_open         on_high     auto-open .md: false | true | on_high
  enabled           true        master switch (or per-repo: pause this repo)

Examples:
  autoreviewer config set timeout_seconds 600
  autoreviewer config set --repo . enabled false
  autoreviewer config get timeout_seconds
  autoreviewer config list
EOF
            ;;
        *) die "unknown subcommand: $sub (try: get|set|unset|list)" ;;
    esac
}

# ---------- update (self-update the tool) ----------

cmd_update() {
    local no_pull=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --no-pull) no_pull=1; shift ;;
            -h|--help)
                cat <<'EOF'
Usage: autoreviewer update [--no-pull]

Pulls the latest autoreviewer source from origin and re-runs install.sh.

  --no-pull    Skip 'git pull' — just re-run install.sh against the
               source as it is on disk now (useful for local dev).

The source location is whatever directory install.sh was last run from.
It's stored in ~/.autoreviewer/config.json under the "source_dir" field.
EOF
                return 0 ;;
            *) die "unknown option: $1" ;;
        esac
    done

    if [ ! -f "$GLOBAL_CONFIG" ]; then
        die "no $GLOBAL_CONFIG — re-run install.sh from a clone first"
    fi

    local src
    src=$(jq -r '.source_dir // empty' "$GLOBAL_CONFIG" 2>/dev/null)
    if [ -z "$src" ]; then
        echo "❌ source_dir not set in $GLOBAL_CONFIG" >&2
        echo "   This usually means autoreviewer was installed before the" >&2
        echo "   update mechanism existed. To fix, run install.sh from a clone:" >&2
        echo "" >&2
        echo "     git clone https://github.com/jsaddnf/auto_reviewer_local.git \\" >&2
        echo "         ~/.autoreviewer-src" >&2
        echo "     ~/.autoreviewer-src/install.sh --force" >&2
        exit 1
    fi
    if [ ! -d "$src" ]; then
        echo "❌ recorded source_dir does not exist: $src" >&2
        echo "   Re-clone and re-run install.sh." >&2
        exit 1
    fi
    if [ ! -x "$src/install.sh" ]; then
        echo "❌ $src/install.sh missing or not executable" >&2
        exit 1
    fi

    if [ "$no_pull" = "0" ]; then
        if [ -d "$src/.git" ]; then
            echo "📥 Pulling latest in $src ..."
            if ! git -C "$src" pull --ff-only; then
                echo "" >&2
                echo "❌ git pull failed (uncommitted changes? non-ff?)." >&2
                echo "   Resolve at $src, then run again." >&2
                echo "   Or: autoreviewer update --no-pull (rebuild current source)" >&2
                exit 1
            fi
        else
            echo "ℹ️  $src is not a git checkout — skipping pull, just rebuilding."
        fi
    fi

    echo "🔄 Re-running install.sh ..."
    "$src/install.sh" --force
}

# ---------- uninstall ----------

cmd_uninstall() {
    echo "Uninstalling autoreviewer..."
    read -rp "This will remove $AUTOREVIEWER_HOME, unset the global git hooks path, and remove the prompt hook from your shell rc. Continue? [y/N] " yn
    [ "$yn" = "y" ] || [ "$yn" = "Y" ] || { echo "Cancelled."; return 0; }

    # Unset core.hooksPath only if it points to us
    local current
    current=$(git config --global --get core.hooksPath 2>/dev/null || echo "")
    if [ "$current" = "$AUTOREVIEWER_HOME/hooks" ] || [ "$current" = "$AUTOREVIEWER_HOME/hooks/" ]; then
        git config --global --unset core.hooksPath
        echo "  unset core.hooksPath"
    elif [ -n "$current" ]; then
        echo "  ⚠️  core.hooksPath is $current (not us); leaving alone"
    fi

    # Remove shell rc additions BEFORE rm -rf so the helper functions are
    # still in memory (they were sourced from lib/config.sh at script start,
    # but the rc cleanup itself doesn't depend on the lib being on disk).
    _ar_shell_hook_uninstall
    _ar_path_hook_uninstall

    rm -rf "$AUTOREVIEWER_HOME"
    rm -f "$HOME/.local/bin/autoreviewer"
    rm -f "/usr/local/bin/autoreviewer"
    echo "✅ Uninstalled. (Per-repo .git/reviews/ data is preserved.)"
}

# ---------- dispatch ----------

cmd="${1:-help}"
shift 2>/dev/null || true

# Self-heal opportunity for "read-style" commands: if this repo was chain-
# installed before but something (typically `pod install`) overwrote
# core.hooksPath, silently put it back. Skipped for explicit hooksPath ops
# (install/uninstall) and for tool-level commands (update/help).
case "$cmd" in
    status|run|log|show|cancel|enable|disable)
        if command -v ar_self_heal_if_needed >/dev/null 2>&1; then
            ar_self_heal_if_needed
        fi
        ;;
esac

case "$cmd" in
    install)   cmd_install "$@" ;;
    enable)    cmd_enable "$@" ;;
    disable)   cmd_disable "$@" ;;
    status)    cmd_status "$@" ;;
    update)    cmd_update "$@" ;;
    run)       cmd_run "$@" ;;
    log)       cmd_log "$@" ;;
    show)      cmd_show "$@" ;;
    clean)     cmd_clean "$@" ;;
    cancel)    cmd_cancel "$@" ;;
    heal)      cmd_heal "$@" ;;
    shell-hook|shellhook) cmd_shell_hook "$@" ;;
    path-hook|pathhook)   cmd_path_hook "$@" ;;
    config)    cmd_config "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    help|-h|--help) cmd_help ;;
    *) die "unknown command: $cmd (try 'autoreviewer help')" ;;
esac
